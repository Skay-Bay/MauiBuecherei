<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBuecherei.AusleiheDetailPage"
             Title="Neue Ausleihe">
    <Grid RowDefinitions="Auto,*" Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="Buchnummer" FontAttributes="Bold" />
            <Entry x:Name="EntryBuchnummer" Placeholder="z.B. 2026-90001" />

            <Label Text="Ausweisnummer des Schülers" FontAttributes="Bold" />
            <Entry x:Name="EntryAusweisnummer" Placeholder="Ausweisnummer (0 = anonym)" />

            <Button Text="Ausleihen" Clicked="OnSaveClicked" HeightRequest="50" />
            <Button Text="Abbrechen" Clicked="OnCancelClicked" HeightRequest="50" />
        </VerticalStackLayout>

        <ActivityIndicator Grid.RowSpan="2" IsVisible="False" x:Name="LoadingIndicator"
                           HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5" />
    </Grid>
</ContentPage>
