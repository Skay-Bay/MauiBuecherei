<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBuecherei.MainPage"
             Title="Bibliothek">
    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

        <Label Text="Bibliotheksverwaltung" FontSize="28" HorizontalOptions="Center" Margin="0,0,0,30"/>

        <Button Text="SchülerInnen" 
                Clicked="OnSchülerInClicked" 
                HeightRequest="60" FontSize="18"/>

        <Button Text="Bücher" 
                Clicked="OnBuchClicked" 
                HeightRequest="60" FontSize="18"/>

        <Button Text="Ausleihen" 
                Clicked="OnAusleiheClicked" 
                HeightRequest="60" FontSize="18"/>

        <Button Text="Statistik" 
                Clicked="OnStatistikClicked" 
                HeightRequest="60" FontSize="18"/>

        <Button Text="Suche" 
        Clicked="OnSearchClicked" 
        HeightRequest="60" FontSize="18"/>

    </VerticalStackLayout>
</ContentPage>