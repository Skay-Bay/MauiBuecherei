<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiBuecherei.ViewModels"
             xmlns:models="clr-namespace:MauiBuecherei.Models"
             x:Class="MauiBuecherei.SchülerInListPage"
             Title="SchülerInnen">

    <Grid RowDefinitions="Auto,*" Padding="15">
        <Button Text="+ Neuer Schüler"
                Command="{Binding CreateSchülerInCommand}"
                Margin="0,5" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding SchülerIn}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SchülerInDto">
                    <Grid Padding="5" ColumnDefinitions="*, Auto, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label FontAttributes="Bold">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Ausweisnr.: " />
                                        <Span Text="{Binding Ausweisnummer}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="{Binding Vorname, StringFormat='Vorname: {0}'}" />
                            <Label Text="{Binding Nachname, StringFormat='Nachname: {0}'}" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="3">
                            <Button Text="✏️"
                                    HeightRequest="32" WidthRequest="40" Padding="0" FontSize="14"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:SchülerInListViewModel}}, Path=EditSchülerInCommand}"
                                    CommandParameter="{Binding .}" />
                            <Button Text="🗑️"
                                    HeightRequest="32" WidthRequest="40" Padding="0" FontSize="14"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:SchülerInListViewModel}}, Path=DeleteSchülerInCommand}"
                                    CommandParameter="{Binding .}" />
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="2" IsVisible="{Binding IsBusy}" 
                           HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5" />
    </Grid>
</ContentPage>