<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBuecherei.BulkAusleihePage"
             Title="Bulk-Ausleihe">
    <Grid RowDefinitions="Auto,*" Padding="20">
        <VerticalStackLayout Spacing="10">
            <Label Text="Schüler-Ausweisnummer" FontAttributes="Bold" />
            <Entry x:Name="EntryAusweisnummer" Placeholder="z.B. 500001" />

            <Label Text="Buchnummern (mit Komma getrennt)" FontAttributes="Bold" />
            <Editor x:Name="EditorBuchnummern" Placeholder="2026-90001,2026-90002,..." HeightRequest="100" />

            <Button Text="Ausleihen" Clicked="OnBulkClicked" HeightRequest="50" />
            <Button Text="Abbrechen" Clicked="OnCancelClicked" HeightRequest="50" />
        </VerticalStackLayout>

        <ActivityIndicator Grid.RowSpan="2" IsVisible="False" x:Name="LoadingIndicator"
                           HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5" />
    </Grid>
</ContentPage>
