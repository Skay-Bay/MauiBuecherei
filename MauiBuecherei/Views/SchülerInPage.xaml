<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiBuecherei.Views"
             x:Class="MauiBuecherei.Views.SchülerInPage"
             Title="SchülerInnen">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="10">
        <!-- Neuer Schüler Button -->
        <Button Grid.Row="0" Text="➕ Neue/r SchülerIn" Clicked="OnNewSchülerInClicked" Margin="0,0,0,10" />

        <!-- Suchfeld -->
        <Border Grid.Row="1" Stroke="LightGray" StrokeThickness="1" Padding="5" Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="🔍" VerticalOptions="Center" Margin="5,0" />
                <Entry Grid.Column="1" x:Name="SearchEntry" Placeholder="Suche nach Name oder Ausweisnummer..." 
                       TextChanged="OnSearchTextChanged" />
            </Grid>
        </Border>

        <!-- Tabellenkopf -->
        <Grid Grid.Row="2" ColumnDefinitions="80,*,*,100,120" Padding="10,5" BackgroundColor="#f0f0f0">
            <Label Grid.Column="0" Text="Nr." FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Vorname" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Nachname" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Status" FontAttributes="Bold" />
            <Label Grid.Column="4" Text="Aktionen" FontAttributes="Bold" HorizontalTextAlignment="End" />
        </Grid>

        <!-- Liste der SchülerInnen -->
        <CollectionView x:Name="SchülerInCollectionView" Grid.Row="2" Margin="0,30,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="80,*,*,100,120" Padding="10,5">
                        <Label Grid.Column="0" Text="{Binding Ausweisnummer}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding Vorname}" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="{Binding Nachname}" VerticalOptions="Center" />

                        <!-- Status -->
                        <Grid Grid.Column="3" VerticalOptions="Center">
                            <Label Text="⚠️ Ausleihen" TextColor="Orange" IsVisible="{Binding HatAusleihen}" />
                            <Label Text="✅ Keine" TextColor="Green" IsVisible="{Binding HatAusleihen, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>

                        <!-- Aktionen -->
                        <HorizontalStackLayout Grid.Column="4" Spacing="5" HorizontalOptions="End">
                            <Button Text="👁️" Clicked="OnDetailsClicked" CommandParameter="{Binding .}" BackgroundColor="LightBlue" />
                            <Button Text="✏️" Clicked="OnEditClicked" CommandParameter="{Binding .}" BackgroundColor="LightYellow" />
                            <Button Text="🗑️" Clicked="OnDeleteClicked" CommandParameter="{Binding .}" BackgroundColor="LightCoral" 
                                    IsEnabled="{Binding HatAusleihen, Converter={StaticResource InverseBoolConverter}}" />
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Ladeindikator -->
        <ActivityIndicator x:Name="LoadingIndicator" Grid.Row="3" IsRunning="False" HeightRequest="30" />
    </Grid>
</ContentPage>
