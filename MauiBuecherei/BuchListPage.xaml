<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiBuecherei.ViewModels"
             x:Class="MauiBuecherei.BuchListPage"
             Title="Bücher">
    <Grid RowDefinitions="Auto,Auto,*" Padding="15">
        <!-- Suchleiste -->
        <SearchBar Placeholder="Titel, Autor, ISBN..." 
                   Text="{Binding Suchbegriff}" 
                   SearchCommand="{Binding SearchCommand}" />

        <!-- Neues Buch Button -->
        <Button Grid.Row="1" Text="Neues Buch" Command="{Binding CreateBuchCommand}" Margin="0,5" />

        <!-- Liste der Bücher -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Buecher}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Löschen" BackgroundColor="Red" 
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:BuchListViewModel}}, Path=DeleteBuchCommand}" 
                                           CommandParameter="{Binding .}" />
                                <SwipeItem Text="Bearbeiten" BackgroundColor="Orange" 
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:BuchListViewModel}}, Path=EditBuchCommand}" 
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="10">
                            <VerticalStackLayout>
                                <Label Text="{Binding Titel}" FontSize="Large" FontAttributes="Bold" />
                                <Label Text="{Binding AutorInnen}" />
                                <Label Text="{Binding Buchnummer}" FontSize="Small" TextColor="Gray" />
                                <Label Text="{Binding ISBN}" FontSize="Small" />
                            </VerticalStackLayout>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="3" IsVisible="{Binding IsBusy}" 
                           HorizontalOptions="Center" VerticalOptions="Center" Scale="1.5" />
    </Grid>
</ContentPage>