<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiBuecherei.ViewModels"
             xmlns:models="clr-namespace:MauiBuecherei.Models"
             x:Class="MauiBuecherei.StatistikPage"
             Title="Statistik">

    <RefreshView Command="{Binding LoadStatistikCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="15">
                <!-- Übersicht -->
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10">
                    <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="LightBlue" Padding="15">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="Gesamtausleihen" FontSize="14" />
                            <Label Text="{Binding GesamtAusleihen}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="LightGreen" Padding="15">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="Aktive Ausleihen" FontSize="14" />
                            <Label Text="{Binding AktiveAusleihen}" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Top Bücher -->
                <Label Text="Top 10 Bücher" FontSize="18" FontAttributes="Bold" />

                <CollectionView ItemsSource="{Binding TopBuecher}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TopBuchDto">
                            <Grid Padding="5" ColumnDefinitions="*, Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Titel}" FontSize="16" />
                                    <Label Text="{Binding Buchnummer, StringFormat='Nr. {0}'}" FontSize="12" TextColor="Gray" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding Anzahl, StringFormat='{0}x'}" 
                                       FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>